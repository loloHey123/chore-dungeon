# ─────────────────────────────────────────────────────────────
#  CHORE DUNGEON — configuration
#  Copy this file to ".env" and fill in the values you need.
# ─────────────────────────────────────────────────────────────

# Server
PORT=8787
# A comma-separated allowlist of origins that may call the API.
# Include your GitHub Pages URL once you deploy the frontend.
# Example: https://yourname.github.io
CORS_ORIGINS=http://localhost:8787,http://127.0.0.1:8787

# Timezone used for all scheduled jobs (Sunday/Monday/Saturday texts).
# Use an IANA name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Los_Angeles

# A shared secret. Roommates type this once on the website to "log in".
# Keep it simple — it's a friendly gate, not Fort Knox.
HOUSE_PASSWORD=dungeonmaster

# ─────────────────────────────────────────────────────────────
#  MESSAGING — choose ONE channel: console | telegram | signal | twilio
# ─────────────────────────────────────────────────────────────
# console  = demo mode. Nothing is actually sent; "texts" appear in the
#            app's Activity log. Great for trying it out.
# telegram = recommended. No phone number — create a bot with @BotFather.
MESSAGING=console

# --- Telegram (recommended: no phone number) -----------------
# 1. Message @BotFather → /newbot → copy the token here.
# 2. Add the bot to your group; it learns the group's chat id automatically
#    the first time anyone posts (or pin one explicitly in TELEGRAM_CHAT_ID).
# 3. In @BotFather → /setprivacy → Disable, so the bot can read plain replies
#    like "done" (otherwise only /commands are visible to it in groups).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_SECONDS=2

# Optional: lets Choremaster riff back in character on messages that aren't a
# recognized command (e.g. "@bot whip me", "@bot rate my week"). Without this,
# unrecognized messages just get a plain "didn't understand" reply.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CHOREMASTER_AI_MODEL=claude-haiku-4-5-20251001

# --- Signal (no bot API — needs a phone number for the bot) ---
# Requires signal-cli installed and registered to SIGNAL_NUMBER.
# See README "Setting up Signal". SIGNAL_GROUP_ID is the base64 group id
# printed by:  signal-cli -a "$SIGNAL_NUMBER" listGroups
SIGNAL_NUMBER=+15551234567
SIGNAL_GROUP_ID=
# How often (seconds) to poll Signal for incoming replies.
SIGNAL_POLL_SECONDS=15

# --- Twilio (fallback: individual SMS) -----------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15550009999
